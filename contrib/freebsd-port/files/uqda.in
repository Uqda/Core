#!/bin/sh
#
# For installation via FreeBSD ports. Installed automatically by the port.
# Paths below match a default PREFIX=/usr/local; adjust if you use a non-standard PREFIX.
#
# Put uqda and uqdactl in /usr/local/sbin, then:
#   chmod +x /usr/local/etc/rc.d/uqda /usr/local/sbin/uqda /usr/local/sbin/uqdactl
#
# PROVIDE: uqda
# REQUIRE: networking
# KEYWORD: shutdown

. /etc/rc.subr

name="uqda"
rcvar="uqda_enable"

start_cmd="${name}_start"
stop_cmd="${name}_stop"

pidfile="/var/run/${name}.pid"
command="/usr/sbin/daemon"

uqda_start()
{
	test ! -x /usr/local/sbin/uqda && (
		logger -s -t uqda "Warning: /usr/local/sbin/uqda is missing or not executable"
		logger -s -t uqda "Install uqda into /usr/local/sbin and chmod +x"
		return 1
	)

	test ! -f /usr/local/etc/uqda.conf && (
		logger -s -t uqda "Generating new configuration file into /usr/local/etc/uqda.conf"
		(umask 037 && /usr/local/sbin/uqda -genconf > /usr/local/etc/uqda.conf)
	)

	tap_path="$(cat /usr/local/etc/uqda.conf | egrep -o '/dev/tap[0-9]{1,2}$')"
	tap_name="$(echo -n ${tap_path} | tr -d '/dev/')"

	/sbin/ifconfig ${tap_name} >/dev/null 2>&1 || (
		logger -s -t uqda "Creating ${tap_name} adapter"
		/sbin/ifconfig ${tap_name} create || logger -s -t uqda "Failed to create ${tap_name} adapter"
	)

	logger -s -t uqda "Starting uqda"
	${command} -P ${pidfile} -r -f /usr/local/sbin/uqda -useconffile /usr/local/etc/uqda.conf \
		1>/var/log/uqda.stdout.log \
		2>/var/log/uqda.stderr.log &
}

uqda_stop()
{
	logger -s -t uqda "Stopping uqda"
	test -f ${pidfile} && kill -TERM $(cat ${pidfile})

	tap_path="$(cat /usr/local/etc/uqda.conf | grep /dev/tap | egrep -o '/dev/.*$')"
	tap_name="$(echo -n ${tap_path} | tr -d '/dev/')"

	/sbin/ifconfig ${tap_name} >/dev/null 2>&1 && (
		logger -s -t uqda "Destroying ${tap_name} adapter"
		/sbin/ifconfig ${tap_name} destroy || logger -s -t uqda "Failed to destroy ${tap_name} adapter"
	)
}

load_rc_config $name
: ${uqda_enable:=no}

run_rc_command "$1"
